---
interface Props {
	title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="es">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Astro description" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title}</title>
	</head>
	<body>
		<slot />
	</body>
</html>
<style is:global>
	html {
		font-family: system-ui, sans-serif;
		background: 
			/* Degradado radial centrado desde la parte superior */
			radial-gradient(
				circle at top center, 
				rgba(200, 0, 255, 0.4) 0%, 
				rgba(128, 0, 255, 0.2) 50%, 
				transparent 70%
			),
			/* Fondo base de morado oscuro */
			linear-gradient(
				to bottom, 
				#1a1a2e, 
				#16213E
			);
		background-attachment: fixed;
		min-height: 100vh;
		color: #E0E0E0;
		line-height: 1.6;
		overflow-x: hidden;
	}

	body {
		min-height: 100vh;
		margin: 0;
		padding: 0;
	}

	/* Asegura scrolling suave y optimizado */
	html {
		scroll-behavior: smooth;
		-webkit-font-smoothing: antialiased;
		-moz-osx-font-smoothing: grayscale;
		text-rendering: optimizeLegibility;
	}

	/* Mejora la selección de texto */
	::selection {
		background-color: rgba(200, 0, 255, 0.3);
		color: #ffffff;
	}
</style>