---
interface Props {
  title: string;
  description: string;
  image: string;
  tools: {
    name: string;
    icon: string;
  }[];
  codeLink: string;
  previewLink: string;
}

const { title, description, image, tools, codeLink, previewLink } = Astro.props;
---

<article class="flex gap-6 rounded-lg overflow-hidden p-4 max-w-4xl">
  <!-- Project Image -->
  <div class="w-1/2">
    <img 
      src={image} 
      alt={`Screenshot of ${title} project`}
      class="w-full h-full object-cover rounded-lg"
    />
  </div>

  <!-- Project Info -->
  <div class="w-1/2 flex flex-col gap-4">
    <h3 class="text-2xl font-bold text-white">{title}</h3>
    
    <!-- Tools -->
    <div class="flex gap-3 flex-wrap">
      {tools.map((tool) => (
        <div class="flex items-center gap-2 bg-[#464F5B] bg-opacity-30 px-3 py-1 rounded-full">
          <img src={tool.icon} alt={tool.name} class="w-5 h-5" />
          <span class="text-gray-300 text-sm">{tool.name}</span>
        </div>
      ))}
    </div>

    <!-- Description -->
    <p class="text-gray-300">
      {description}
    </p>

    <!-- Buttons -->
    <div class="flex gap-4 mt-auto text-white">
      <a 
        href={codeLink}
        target="_blank"
        class="flex items-center gap-2 px-4 py-2 bg-[#464F5B] rounded-lg hover:bg-[#a4b0bc] transition-colors"
      >
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-github">
        <path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"/>
        <path d="M9 18c-4.51 2-5-2-7-2"/></svg>
        Code
      </a>
      <a 
        href={previewLink}
        target="_blank"
        class="flex items-center gap-2 px-4 py-2 bg-[#464F5B] rounded-lg hover:bg-[#a4b0bc] transition-colors"
      >
      <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-link">
        <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>
        <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
        Preview
      </a>
    </div>
  </div>
</article>