---
import ProjectCard from "../components/ProjectCard.astro";
import Layout from "../layouts/Layout.astro";

// Datos de ejemplo - puedes mover esto a un archivo separado
const projects = [
  {
    title: "Clinica Odontologia",
    description:
      "Se realizo un sitema para una clinica odontologia con las características de poder agendar citas, imprimir constancias y como uso principal es la creacion de historial clinico para sus pacientes.",
    image: "/assets/proyectos.jpg",
    tools: [
      {
        name: "Java",
        icon: "/assets/java.png",
      },
      {
        name: "NetBeans",
        icon: "/assets/netbeans.png",
      },
      {
        name: "SQL Server",
        icon: "/assets/sql.png",
      },
    ],
    codeLink: "#",
    previewLink: "#",
  },

  // Puedes agregar más proyectos aquí
];
---

<Layout title="My Portfolio">
  <section
  id="Landing"
  class="min-h-screen flex flex-col md:flex-row items-center justify-center gap-8 px-6 md:px-16 lg:px-32 py-20"
>
  <!-- Texto a la izquierda -->
  <div class="flex flex-col items-start text-left">
    <h1 class="text-4xl md:text-6xl font-bold mb-2 text-pink-400">Hello!!</h1>
    <h2 class="text-3xl md:text-5xl font-bold mb-4 text-white">
      I am Juan Turcios
    </h2>
    <h3 class="text-lg md:text-2xl text-gray-300 mb-6">
      Computer Science Engineer
    </h3>
    <p class="max-w-xl text-sm md:text-lg text-gray-200 mb-6">
      I am a Computer Science Engineering student with experience in design,
      analysis, and programming of web pages and software. I excel in teamwork
      and have a natural ability to learn quickly.
    </p>
    <div class="flex items-center gap-4">
      <!-- Botón de Curriculum -->
      <a
        href="/curriculum.pdf"
        class="bg-pink-500 text-white py-2 px-6 rounded-full text-sm flex items-center gap-2 hover:bg-pink-600 transition duration-300"
        download
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="lucide lucide-download"
        >
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
          <polyline points="7 10 12 15 17 10"></polyline>
          <line x1="12" x2="12" y1="15" y2="3"></line>
        </svg>
        Curriculum
      </a>

      <!-- Redes sociales -->
      <a
        href="https://instagram.com/"
        class="text-gray-300 hover:text-white transition duration-300 p-2"
        aria-label="Instagram"
        target="_blank"
        rel="noopener noreferrer"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="lucide lucide-instagram"
        >
          <title>Instagram</title>
          <rect width="20" height="20" x="2" y="2" rx="5" ry="5"></rect>
          <path
            d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"
          ></path>
          <line x1="17.5" x2="17.51" y1="6.5" y2="6.5"></line>
        </svg>
      </a>

      <a
        href="https://github.com/"
        class="text-gray-300 hover:text-white transition duration-300 p-2"
        aria-label="GitHub"
        target="_blank"
        rel="noopener noreferrer"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="lucide lucide-github"
        >
          <title>GitHub</title>
          <path
            d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"
          ></path>
          <path d="M9 18c-4.51 2-5-2-7-2"></path>
        </svg>
      </a>

      <a
        href="https://linkedin.com/"
        class="text-gray-300 hover:text-white transition duration-300 p-2"
        aria-label="LinkedIn"
        target="_blank"
        rel="noopener noreferrer"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="lucide lucide-linkedin"
        >
          <title>LinkedIn</title>
          <path
            d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-4 0v7H10v-7a6 6 0 0 1 6-6z"
          ></path>
          <rect width="4" height="12" x="2" y="9"></rect>
          <circle cx="4" cy="4" r="2"></circle>
        </svg>
      </a>
    </div>
  </div>

  <!-- Foto a la derecha -->
  <div class="flex justify-center items-center">
    <img
      src="/assets/perfil.png"
      alt="Juan Turcios"
    />
  </div>
</section>


  <section
    class="min-h-screen flex flex-col items-center justify-center py-20 px-4"
  >
    <div class="max-w-7xl w-full">
      <h2 class="text-4xl font-bold text-center text-white mb-16">
        My Projects
      </h2>

      <div class="flex flex-col gap-8 items-center">
        {projects.map((project) => <ProjectCard {...project} />)}
      </div>
    </div>
  </section>
</Layout>
