---
import ProjectCard from "../components/ProjectCard.astro";
import Skills from "../components/Skills.astro";
import Layout from "../layouts/Layout.astro";

// Datos de ejemplo - puedes mover esto a un archivo separado
const projects = [
  {
    title: "Dental Health",
    description:
      "A system was developed for a dental clinic with the features of scheduling appointments, printing certificates, and, as its primary use, the creation of clinical histories for its patients.",
    image: "/assets/img/proyectos.jpg",
    tools: [
      {
        name: "Java",
        icon: "/assets/icons/java.png",
      },
      {
        name: "NetBeans",
        icon: "/assets/icons/netbeans.png",
      },
      {
        name: "SQL Server",
        icon: "/assets/icons/sql.png",
      },
    ],
    codeLink: "https://github.com/wJuanca/clinica-odontologica",
    previewLink: "#",
  },
  {
    title: "NGO Huellas de Amor",
    description:
      "A website was developed for an NGO dedicated to rescuing animals and giving them a new life and a new family. This website has the ability to receive donations to support the NGO.",
    image: "/assets/img/proyectos.jpg",
    tools: [
      {
        name: "Vite",
        icon: "/assets/icons/vite.png",
      },
      {
        name: "React",
        icon: "/assets/icons/react.png",
      },
      {
        name: "JavaScript",
        icon: "/assets/icons/javascript.png",
      },
      {
        name: "Less",
        icon: "/assets/icons/less.png",
      },
    ],
    codeLink: "https://github.com/wJuanca/ProyectoFinal",
    previewLink: "https://wjuanca.github.io/ProyectoFinal/",
  },
  {
    title: "Chrishop",
    description:
      "Development of an e-commerce platform for selling personalized products, featuring functionalities such as category filtering, highlighted product display, and responsive design.",
    image: "/assets/img/proyectos.jpg",
    tools: [
      {
        name: "Astro",
        icon: "/assets/icons/astro.png",
      },
      {
        name: "Tailwind",
        icon: "/assets/icons/tailwind.png",
      },
      {
        name: "JavaScript",
        icon: "/assets/icons/javascript.png",
      },
      {
        name: "VsCode",
        icon: "/assets/icons/vscode.png",
      },
    ],
    codeLink: "https://github.com/wJuanca/chrishop",
    previewLink: "https://wjuanca.github.io/chrishop/",
  },

  // Puedes agregar más proyectos aquí
];

const languages = [
    { name: 'JavaScript', icon: 'logos:javascript' },
    { name: 'HTML', icon: 'devicon:html5' },
    { name: 'Python', icon: 'devicon:css3' },
    { name: 'Sql Server', icon: 'devicon:microsoftsqlserver' },
    { name: 'Java', icon: 'logos:java' }
];

const tools = [
    { name: 'Git', icon: 'logos:git-icon' },
    { name: 'Figma', icon: 'logos:figma' },
    { name: 'Astro', icon: 'vscode-icons:file-type-astro' },
    { name: 'Android Studio', icon: 'devicon:androidstudio' },
    { name: 'Node.js', icon: 'logos:nodejs-icon' },
    { name: 'Tailwind', icon: 'logos:tailwindcss-icon' },
    { name: 'Vercel', icon: 'logos:vercel-icon' },
    { name: 'PhotoShop', icon: 'devicon:photoshop' },
    { name: 'DaVinci Resolve', icon: 'simple-icons:davinciresolve' },
    { name: 'Less', icon: 'logos:less' }
];
---

<Layout title="My Portfolio">
  <section
    id="Landing"
    class="min-h-screen flex flex-col md:flex-row items-center justify-center px-6 md:px-24 lg:px-48 relative overflow-hidden"
  >
    <!-- Texto a la izquierda -->
    <div
      class="flex flex-col items-start text-left w-full md:w-1/2 space-y-4 animate-fadeIn px-8"
    >
      <h1
        class="text-4xl md:text-6xl font-bold text-pink-400 hover:text-pink-300 transition-colors duration-300"
      >
        ¡Hola!
      </h1>
      <h2 class="text-3xl md:text-5xl font-bold text-white">
        Soy Juan Turcios
      </h2>
      <h3 class="text-lg md:text-2xl text-gray-300 font-medium">
        Computer Science Engineer
      </h3>
      <p class="text-sm md:text-lg text-gray-200 max-w-xl leading-relaxed">
        Soy estudiante de Ingeniería en Ciencias de la Computación con
        experiencia en diseño, análisis y programación de páginas web y
        software. Me destaco en el trabajo en equipo y tengo una capacidad
        natural para aprender rápidamente.
      </p>

      <div
        class="flex flex-col sm:flex-row items-start sm:items-center gap-6 mt-8"
      >
        <!-- Botón de Curriculum -->
        <a
          href="/curriculum.pdf"
          class="group bg-pink-500 text-white py-3 px-8 rounded-full text-sm flex items-center gap-2 hover:bg-pink-600 transition-all duration-300 transform hover:scale-105"
          download
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="lucide lucide-arrow-down-from-line"
            ><path d="M19 3H5"></path><path d="M12 21V7"></path><path
              d="m6 15 6 6 6-6"></path></svg
          >
          Descargar CV
        </a>
      </div>

      <!-- Redes sociales -->
      <div class="flex items-center gap-6 mt-8">
        <a
          href="https://instagram.com/"
          class="text-gray-300 hover:text-pink-400 transition-all duration-300 transform hover:scale-110"
          aria-label="Instagram"
          target="_blank"
          rel="noopener noreferrer"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="lucide lucide-instagram"
          >
            <title>Instagram</title>
            <rect width="20" height="20" x="2" y="2" rx="5" ry="5"></rect>
            <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path>
            <line x1="17.5" x2="17.51" y1="6.5" y2="6.5"></line>
          </svg>
        </a>

        <a
          href="https://github.com/"
          class="text-gray-300 hover:text-white transition-all duration-300 transform hover:scale-110"
          aria-label="GitHub"
          target="_blank"
          rel="noopener noreferrer"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="lucide lucide-github"
          >
            <title>GitHub</title>
            <path
              d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"
            ></path>
            <path d="M9 18c-4.51 2-5-2-7-2"></path>
          </svg>
        </a>

        <a
          href="https://linkedin.com/"
          class="text-gray-300 hover:text-blue-500 transition-all duration-300 transform hover:scale-110"
          aria-label="LinkedIn"
          target="_blank"
          rel="noopener noreferrer"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="24"
            height="24"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="lucide lucide-linkedin"
          >
            <title>LinkedIn</title>
            <path
              d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-4 0v7H10v-7a6 6 0 0 1 6-6z"
            ></path>
            <rect width="4" height="12" x="2" y="9"></rect>
            <circle cx="4" cy="4" r="2"></circle>
          </svg>
        </a>
      </div>
    </div>

    <!-- Foto a la derecha -->
    <div
      class="w-full md:w-1/2 flex justify-center items-center mt-12 md:mt-0 px-8"
    >
      <div class="relative">
        <div
          class="absolute inset-0 bg-pink-500 rounded-full blur-3xl opacity-20"
        >
        </div>
        <img
          src="/assets/img/perfil.png"
          alt="Juan Turcios"
          class="w-80 h-80 md:w-[450px] md:h-[450px] rounded-full object-cover relative z-10"
        />
      </div>
    </div>

    <!-- Botón de Contacto y flecha de scroll en el pie -->
    <div
      class="absolute bottom-8 left-1/2 transform -translate-x-1/2 flex flex-col items-center gap-8"
    >
      <a
        href="#projects"
        class="group bg-transparent border-2 border-pink-500 text-pink-500 py-3 px-8 rounded-full text-sm flex items-center gap-2 hover:bg-pink-500 hover:text-white transition-all duration-300 transform hover:scale-105"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="lucide lucide-folder-kanban"
          ><path
            d="M4 20h16a2 2 0 0 0 2-2V8a2 2 0 0 0-2-2h-7.93a2 2 0 0 1-1.66-.9l-.82-1.2A2 2 0 0 0 7.93 3H4a2 2 0 0 0-2 2v13c0 1.1.9 2 2 2Z"
          ></path>
          <path d="M8 10v4"></path><path d="M12 10v2"></path><path d="M16 10v6"
          ></path></svg
        >
        Projects
      </a>

      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="24"
        height="24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
        class="text-gray-300 animate-bounce"
      >
        <path d="M12 5v14"></path>
        <path d="m19 12-7 7-7-7"></path>
      </svg>
    </div>
  </section>

  <section id="projects"
    class="min-h-screen flex flex-col items-center justify-center py-20 px-4"
  >
    <div class="max-w-7xl w-full">
      <h2 class="text-4xl font-bold text-center text-white mb-16">
        My Projects
      </h2>

      <div class="flex flex-col gap-8 items-center">
        {projects.map((project) => <ProjectCard {...project} />)}
      </div>
    </div>
  </section>

  <section id="skills" class="min-h-screen flex items-center justify-center">
    <div>
      <h1 class="text-white font-extrabold text-4xl text-center">My Skill</h1>
      <Skills />
    </div>
  </section>

  <section class="min-h-screen w-full flex items-center justify-center py-16 px-4">
    <div class="container mx-auto">
        <h2 class="text-4xl md:text-5xl lg:text-6xl font-bold text-center text-white mb-12 tracking-wider">
            Tecnologías
        </h2>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 max-w-6xl mx-auto">
            {/* Card Lenguajes */}
            <div class="bg-white/10 backdrop-blur-md border border-white/20 rounded-2xl p-6 hover:scale-[1.02] transition-transform duration-300">
                <h3 class="text-2xl font-semibold text-center text-white mb-6">Lenguajes</h3>
                <div class="grid grid-cols-3 gap-4">
                    {languages.map((lang) => (
                        <div class="flex flex-col items-center justify-center space-y-2">
                            <div class="w-16 h-16 bg-white/10 rounded-full flex items-center justify-center">
                                <iconify-icon icon={lang.icon} width="48" height="48" class="text-white"></iconify-icon>
                            </div>
                            <p class="text-sm text-white/80 text-center">{lang.name}</p>
                        </div>
                    ))}
                </div>
            </div>

            {/* Card Herramientas */}
            <div class="bg-white/10 backdrop-blur-md border border-white/20 rounded-2xl p-6 hover:scale-[1.02] transition-transform duration-300">
                <h3 class="text-2xl font-semibold text-center text-white mb-6">Herramientas</h3>
                <div class="grid grid-cols-3 gap-4">
                    {tools.map((tool) => (
                        <div class="flex flex-col items-center justify-center space-y-2">
                            <div class="w-16 h-16 bg-white/10 rounded-full flex items-center justify-center">
                                <iconify-icon icon={tool.icon} width="48" height="48" class="text-white"></iconify-icon>
                            </div>
                            <p class="text-sm text-white/80 text-center">{tool.name}</p>
                        </div>
                    ))}
                </div>
            </div>
        </div>
    </div>
</section>

<script is:inline src="https://cdn.jsdelivr.net/npm/iconify-icon@1.0.8/dist/iconify-icon.min.js"></script>
  
</Layout>
